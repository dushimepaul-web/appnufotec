{
  "expo": {
    "name": "NUFOTEC APP",
    "slug": "nufo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nufo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.nufotec.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.nufotec.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "gradleProperties": {
              "newArchEnabled": "true"
            }
          }
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-video",
        {
          "supportsPictureInPicture": true
        }
      ],
      "expo-audio",
      [
        "expo-media-library",
        {
          "photosPermission": "NUFOTEC a besoin d'acceder a votre galerie pour sauvegarder les videos telechargees.",
          "savePhotosPermission": "NUFOTEC a besoin de sauvegarder les videos dans votre galerie.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-file-system",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow NUFOTEC to access your camera to take photos for consultation."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea2a893a-0e90-4d96-a50d-046cbe43fc96"
      }
    }
  }
}